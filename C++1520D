#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t; cin >> t;
    while (t--){
        int n; cin >> n;
        vector<int> a(n);
        unordered_map<int, int> check;
        long long done = 0;
        for (int i=0; i<n; i++){
            cin >> a[i];
            done += check[a[i] - i];
            check[a[i] - i]++;
        }
        cout << done << "\n";
    }
    return 0;
}
