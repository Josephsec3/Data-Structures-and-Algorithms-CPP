#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t; cin >> t;
    while (t--){
        long long n, c, done=0; cin >> n;
        unordered_map<long long,long long > check;
        for (int i=0; i<n; i++){
            cin >> c;
            done += check[c - i];
            check[c - i]++;
        }
        cout << done << "\n";
    }
}
